{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "An article representing a social media trend.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "summary": { "type": "string" },
        "category": { "type": "string" },
        "platforms": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "publishedAt": { "type": "number", "description": "Timestamp" },
        "views": { "type": "number", "description": "Number of views" }
      },
      "required": ["title", "content", "summary", "category", "publishedAt"]
    },
    "SiteStats": {
      "title": "Site Statistics",
      "description": "Global performance metrics for the application.",
      "type": "object",
      "properties": {
        "totalVisits": { "type": "number" }
      }
    }
  },
  "firestore": {
    "articles/{articleId}": {
      "schema": "Article",
      "description": "Articles generated by AI representing trends."
    },
    "site_stats/{statId}": {
      "schema": "SiteStats",
      "description": "Global usage metrics."
    }
  }
}
